+template<class TDescriptor, class F>
+void TemplatedVocabulary<TDescriptor,F>::saveToBinaryFile(const std::string &filename) const
+{
+    std::ofstream f(filename, std::ios::binary);
+    if(!f.is_open()) throw std::string("Could not open file ") + filename;
+
+    // Header: magic + k + L + scoring + weighting + num_nodes
+    const int32_t magic = 0x44425632;  // "DBV2"
+    int32_t k = m_k, L = m_L;
+    int32_t scoring = (int32_t)m_scoring, weighting = (int32_t)m_weighting;
+    int32_t num_nodes = (int32_t)(m_nodes.size() - 1);  // exclude root
+
+    f.write((const char*)&magic, 4);
+    f.write((const char*)&k, 4);
+    f.write((const char*)&L, 4);
+    f.write((const char*)&scoring, 4);
+    f.write((const char*)&weighting, 4);
+    f.write((const char*)&num_nodes, 4);
+
+    // Per node: parent(i32) isLeaf(i8) descriptor(32 bytes) weight(f64)
+    for(size_t i = 1; i < m_nodes.size(); i++)
+    {
+        const Node& node = m_nodes[i];
+        int32_t parent = (int32_t)node.parent;
+        int8_t isLeaf = node.isLeaf() ? 1 : 0;
+        double weight = node.weight;
+
+        f.write((const char*)&parent, 4);
+        f.write((const char*)&isLeaf, 1);
+        // Write raw descriptor bytes (32 bytes for ORB)
+        f.write((const char*)node.descriptor.data, F::L);
+        f.write((const char*)&weight, 8);
+    }
+    f.close();
+}
+
